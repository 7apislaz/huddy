{
  "name": "@7apislaz/huddy",
  "version": "0.2.3",
  "description": "Tamagotchi-style CLI companion for Claude Code — reactive buddy + optional HUD on the statusline",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "huddy": "./bin/huddy.mjs"
  },
  "files": [
    "dist",
    "bin",
    "docs/commands"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "buddy",
    "tamagotchi",
    "cli",
    "companion",
    "ascii-art"
  ],
  "author": "7apislaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/7apislaz/huddy.git"
  },
  "homepage": "https://github.com/7apislaz/huddy#readme",
  "bugs": {
    "url": "https://github.com/7apislaz/huddy/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
